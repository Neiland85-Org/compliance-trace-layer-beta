# Console UI Environment Variables
# Copy this file to .env and configure for your environment

# Backend API URL (trace service)
VITE_API_URL=http://localhost:4000

# Deploy Engine URL (container orchestration)
VITE_ENGINE_URL=http://localhost:4010

# Environment mode
VITE_MODE=development

# Enable debug logging
VITE_DEBUG=false

# Feature flags
VITE_ENABLE_3D_EFFECTS=true
VITE_ENABLE_COOKIE_BANNER=true
