PORT=4000
# Comma-separated list of allowed CORS origins (no spaces around commas)
# Example: ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
ALLOWED_ORIGINS=http://localhost:5173

# Rate Limiting Configuration
# Rate limiting: time window in milliseconds (default: 15 minutes = 900000ms)
RATE_LIMIT_WINDOW_MS=900000
# Rate limiting: maximum requests per window (default: 100 requests per 15 minutes)
RATE_LIMIT_MAX_REQUESTS=100

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/compliance_trace
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT=30000

# Microservices Configuration (for API Gateway)
TRACE_SERVICE_URL=http://trace-service:4001
COOKIE_CONSENT_SERVICE_URL=http://cookie-consent-service:4002

# Cookie Consent Configuration
CONSENT_VERSION=1.0.0
CONSENT_EXPIRY_MONTHS=12

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
