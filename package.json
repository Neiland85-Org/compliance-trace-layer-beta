{
  "name": "compliance-trace-layer-beta",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "backend": "node packages/trace-engine/server.js",
    "frontend": "npm run dev -w apps/console",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "install:all": "npm install && npm install -w apps/console"
  }
}