# =====================================================
# Docker Compose Environment Variables
# =====================================================
# Copy this file to .env and configure for your environment
# This file is used by docker-compose.yml

# =====================================================
# PostgreSQL Configuration
# =====================================================
POSTGRES_PASSWORD=changeme_secure_password_here
POSTGRES_USER=postgres
POSTGRES_DB=compliance_trace

# =====================================================
# Application Environment
# =====================================================
NODE_ENV=production

# =====================================================
# CORS Configuration
# =====================================================
# Comma-separated list of allowed origins (no spaces)
# For multiple origins: http://localhost:5173,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =====================================================
# Logging Configuration
# =====================================================
LOG_LEVEL=info
LOG_FORMAT=json

# =====================================================
# Security Note
# =====================================================
# IMPORTANT: Never commit the actual .env file to git
# Always use strong, unique passwords in production
# Rotate credentials regularly
# Use secrets management in production (e.g., AWS Secrets Manager, HashiCorp Vault)
