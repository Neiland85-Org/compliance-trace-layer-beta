{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "intake-analysis/**/*.ts",
    "analysis-proposal/**/*.ts",
    "proposal-manifest/**/*.ts",
    "manifest-deployment/**/*.ts",
    "proposal-delivery/**/*.ts",
    "index.ts"
  ],
  "exclude": ["node_modules", "dist", "test"]
}
